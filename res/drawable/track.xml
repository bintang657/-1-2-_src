<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_checked="true">
        <shape
            android:shape="rectangle">
            <solid
                android:color="#ffd50000" />
            <corners
                android:radius="100.0dip" />
            <stroke
                android:width="3.0dip"
                android:color="#ffd50000" />
            <size
                android:height="18.0dip" />
        </shape>
    </item>
    <item
        android:state_checked="false">
        <shape
            android:shape="rectangle">
            <solid
                android:color="#ffe0e0e0" />
            <corners
                android:radius="100.0dip" />
            <stroke
                android:width="3.0dip"
                android:color="#ffe0e0e0" />
            <size
                android:height="18.0dip" />
        </shape>
    </item>
</selector>